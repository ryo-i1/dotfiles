% 2026/02/12 Ryo Ishizuka
% sty/preamble-sp.sty v.1
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{preamble-sp}[2026/02/12 v1.0.0 Space layout]

% --------------------
% Default values
% --------------------

% geometry
\providecommand{\SPGeometry}{top=20truemm,bottom=30truemm,left=20truemm,right=20truemm}

% footer label
\makeatletter
\providecommand{\SP@twodigits}[1]{\ifnum#1<10 0\fi\number#1}
\providecommand{\SPDate}{\number\year/\SP@twodigits{\month}/\SP@twodigits{\day}}
\providecommand{\SPAuthor}{Ryo Ishizuka}
\providecommand{\SPLabel}{}
\providecommand{\SPVer}{-}
\@ifundefined{SP}{}{\renewcommand{\SPVer}{\SP}}
\makeatother

% stretch
\providecommand{\SPStretch}{3.0}


% --------------------
% Setup
% --------------------

% footer
\newcommand{\SPCfootContent}{\SPDate\quad \SPAuthor\quad \SPLabel\quad ver.\SPVer\quad p.\thepage}

% spacing, etc
\newcommand{\ApplySP}{
 \RequirePackage{geometry}
 \RequirePackage{fancyhdr}
 \RequirePackage{setspace}

 % apply geometry
 \expandafter\geometry\expandafter{\SPGeometry}

 % apply spacing
 \setstretch{\SPStretch}

 % apply Page Style
 \pagestyle{fancy}
 \fancyhf{}
 \renewcommand{\headrulewidth}{0pt}
 \renewcommand{\footrulewidth}{0.4pt}
 \cfoot{\SPCfootContent}

 \fancypagestyle{empty} {
  \fancyhf{}
  \renewcommand{\headrulewidth}{0pt}
  \renewcommand{\footrulewidth}{0.4pt}
  \cfoot{\SPCfootContent}
 }
 \fancypagestyle{plain} {
  \fancyhf{}
  \renewcommand{\headrulewidth}{0pt}
  \renewcommand{\footrulewidth}{0.4pt}
  \cfoot{\SPCfootContent}
 }
}


% --------------------
% Apply
% --------------------

\ifdefined\SP
\ApplySP
\fi
